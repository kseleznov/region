generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Place {
  id           Int     @id @default(autoincrement())
  name         String
  category     String
  description  String
  image        String
  photos       Json    @default("[]")
  stars        Float
  price        Int
  address      String
  isOpen       Boolean
  isSaved      Boolean
  workingHours Json
}

model City {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  name        String
  description String
  images      Json   @default("[]")
  location    Json
  weather     Json
}
